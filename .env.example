# StealthMole API v2 credentials (issued to hackathon email).
# Copy to `.env` (gitignored) and fill. NEVER commit real keys.
# adapter/stealthmole.py reads these at connect time; never commit real keys.
STEALTHMOLE_ACCESS_KEY=
STEALTHMOLE_SECRET_KEY=

# Live pipeline safety/config. Use only domains you are authorized to query.
# Copy registry/suppliers.live.example.yaml to a private gitignored location,
# replace its placeholders, and point this variable at that file.
OMIJA_LIVE_REGISTRY=
STEALTHMOLE_QUERY_DOMAINS=
STEALTHMOLE_MODULES=cds
OMIJA_LIVE_DB=out/live/omija-live.sqlite

# Foundry OSDK handoff. Keep real tokens only in `.env`.
FOUNDRY_HOSTNAME=
FOUNDRY_TOKEN=
FOUNDRY_OSDK_INSTALL_CMD=
FOUNDRY_OSDK_PACKAGE=
FOUNDRY_OSDK_MODULE=
FOUNDRY_OSDK_CLIENT=
FOUNDRY_OSDK_AUTH=
FOUNDRY_OSDK_CLIENT_FACTORY=
FOUNDRY_OSDK_OBJECTS_PATH=ontology.objects
FOUNDRY_OSDK_OBJECT_SUPPLIER=Supplier
FOUNDRY_OSDK_OBJECT_PRIME=Prime
FOUNDRY_OSDK_OBJECT_PROGRAM=Program
FOUNDRY_OSDK_OBJECT_CREDENTIAL_EXPOSURE=CredentialExposure
FOUNDRY_OSDK_OBJECT_COMPROMISE_INCIDENT=CompromiseIncident
FOUNDRY_OSDK_OBJECT_NOTIFICATION_DRAFT=NotificationDraft
FOUNDRY_OSDK_LINK_SUBCONTRACTS_TO=subcontractsTo
FOUNDRY_OSDK_LINK_SUPPLIES=supplies
FOUNDRY_OSDK_LINK_RUNS=runs
FOUNDRY_OSDK_LINK_OWNS=domains
FOUNDRY_OSDK_LINK_PRIME_OWNS=domains
FOUNDRY_OSDK_LINK_BELONGS_TO=domain
FOUNDRY_OSDK_LINK_OF=of
FOUNDRY_OSDK_LINK_TARGETS=targets
FOUNDRY_OSDK_LINK_SOURCED_FROM=threat_source
FOUNDRY_OSDK_LINK_LEAKED=credential_exposures
FOUNDRY_OSDK_LINK_TRAVERSES_SUPPLIER=traversesSupplier
FOUNDRY_OSDK_LINK_TRAVERSES_PROGRAM=traversesProgram
FOUNDRY_OSDK_LINK_CITES_INCIDENT=citesIncident
