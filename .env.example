# StealthMole API v2 credentials (issued to hackathon email).
# Copy to `.env` (gitignored) and fill. NEVER commit real keys.
# adapter/stealthmole.py reads these at connect time; never commit real keys.
STEALTHMOLE_ACCESS_KEY=
STEALTHMOLE_SECRET_KEY=

# Live pipeline safety/config. Use only domains you are authorized to query.
# Copy registry/suppliers.live.example.yaml to a private gitignored location,
# replace its placeholders, and point this variable at that file.
OMIJA_LIVE_REGISTRY=
STEALTHMOLE_QUERY_DOMAINS=
STEALTHMOLE_MODULES=cds
OMIJA_LIVE_DB=out/live/omija-live.sqlite
