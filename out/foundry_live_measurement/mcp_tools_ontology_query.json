[
  {
    "name": "get_foundry_ontology_rid",
    "title": "get_foundry_ontology_rid",
    "description": "Fetches the Ontology RID for a given Foundry OSDK application, local repository, or lists all available ontologies.\n- Ontology RIDs are required when interacting with a Foundry Ontology.\n- If neither application nor repository is provided, all available ontologies will be listed.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "applicationRidLocator": {
          "anyOf": [
            {
              "anyOf": [
                {
                  "type": "object",
                  "properties": {
                    "thirdPartyApplicationRid": {
                      "type": "string",
                      "description": "Third Party Application. (eg: ri.third-party-applications.main.application.{UUID}). undefined. "
                    }
                  },
                  "required": [
                    "thirdPartyApplicationRid"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "gitProjectPath": {
                      "type": "string",
                      "description": "A path to a local git clone of a Foundry repository where a third party application rid can be read."
                    }
                  },
                  "required": [
                    "gitProjectPath"
                  ],
                  "additionalProperties": false
                }
              ]
            },
            {
              "type": "null"
            }
          ],
          "description": "Optional. If not provided, all available ontologies will be listed."
        }
      },
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    },
    "annotations": {
      "readOnlyHint": true,
      "destructiveHint": false,
      "idempotentHint": true,
      "openWorldHint": false
    },
    "execution": {
      "taskSupport": "forbidden"
    }
  },
  {
    "name": "view_foundry_object_type",
    "title": "view_foundry_object_type",
    "description": "View an existing object type.\n\nThis tool allows you to view the definition of an object type in the ontology, including its properties, link types, and action types.\n\nThis tool can be used repeatedly/recursively to traverse the Ontology graph, by looking at its LinkTypes.\nYou can offer this option to the user when they are asking vague details about ontology entities, as traversing the ontology can provide clarity on its structure and potential uses.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "globalBranchRid": {
          "anyOf": [
            {
              "type": "string",
              "description": "The global branch rid: e.g. ri.branch..branch.{UUID}.\nMust be provided if available objects within a branch are not visible on other branches or in the main ontology"
            },
            {
              "type": "null"
            }
          ],
          "description": "The global branch rid: e.g. ri.branch..branch.{UUID}.\nMust be provided if available objects within a branch are not visible on other branches or in the main ontology"
        },
        "objectType": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "objectTypeRid": {
                  "type": "string",
                  "description": "Ontology Object Type RID. (eg: ri.ontology.main.object-type.{UUID}). undefined. "
                }
              },
              "required": [
                "objectTypeRid"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "objectTypeId": {
                  "type": "string",
                  "description": "This is a human readable id for the ObjectType. Valid ObjectTypeIds have the following conditions:\n* Preferably kebab-case (but snake_case and cameCase is also allowed)\n* The first character must be a lower case letter, subsequent characters can be a lower case letter or number.\n* No special characters are allowed."
                }
              },
              "required": [
                "objectTypeId"
              ],
              "additionalProperties": false
            }
          ]
        }
      },
      "required": [
        "objectType"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    },
    "annotations": {
      "readOnlyHint": true,
      "destructiveHint": false,
      "idempotentHint": true,
      "openWorldHint": false
    },
    "execution": {
      "taskSupport": "forbidden"
    }
